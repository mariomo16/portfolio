---
import { useTranslations } from "../i18n/utils";

const { t } = useTranslations(Astro.currentLocale || "es");

const links = [
  {
    label: t("contact.email_label"),
    href: "mailto:moralesortegamario02@gmail.com",
    icon: "email",
  },
  {
    label: t("contact.linkedin_label"),
    href: "https://www.linkedin.com/in/ortega02/",
    icon: "linkedin",
  },
  {
    label: t("contact.github_label"),
    href: "https://github.com/mariomo16",
    icon: "github",
  },
];
---

<section class="contact" id="contact">
  <div class="container">
    <h2 class="section-title">{t("contact.title")}</h2>
    <p class="contact-description">{t("contact.description")}</p>
    <div class="contact-links">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="contact-card"
            target={link.href.startsWith("mailto") ? undefined : "_blank"}
            rel="noopener noreferrer"
          >
            <span class="contact-icon">
              {link.icon === "email" && (
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              )}
              {link.icon === "github" && (
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
              )}
            </span>
            <span class="contact-label">{link.label}</span>
            <svg
              class="contact-arrow"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M7 17l9.2-9.2M17 17V7H7" />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-description {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    margin-bottom: 40px;
    max-width: 640px;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 16px;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 28px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.2s;
    min-width: 200px;
    flex: 1;
  }

  .contact-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 1rem;
    font-weight: 600;
    flex: 1;
  }

  .contact-arrow {
    color: var(--text-muted);
    transition: transform 0.2s;
  }

  .contact-card:hover .contact-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .contact-links {
      flex-direction: column;
    }

    .contact-card {
      min-width: unset;
    }
  }
</style>
