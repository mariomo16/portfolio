---
import arrowIcon from "../assets/arrow-icon.svg?raw";
import githubIcon from "../assets/github-icon.svg?raw";
import linkedinIcon from "../assets/linkedin-icon.svg?raw";
import mailIcon from "../assets/mail-icon.svg?raw";
import { useTranslations } from "../i18n/utils";

const { t } = useTranslations(Astro.currentLocale || "es");

const links = [
  {
    label: t("contact.email_label"),
    href: "mailto:moralesortegamario02@gmail.com",
    icon: mailIcon,
  },
  {
    label: t("contact.linkedin_label"),
    href: "https://www.linkedin.com/in/ortega02/",
    icon: linkedinIcon,
  },
  {
    label: t("contact.github_label"),
    href: "https://github.com/mariomo16",
    icon: githubIcon,
  },
];
---

<section class="contact" id="contact">
  <div class="container">
    <h2 class="section-title">{t("contact.title")}</h2>
    <p class="contact-description">{t("contact.description")}</p>
    <div class="contact-links">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="contact-card"
            target={link.href.startsWith("mailto") ? undefined : "_blank"}
            rel="noopener noreferrer"
          >
            <span class="contact-icon"><Fragment set:html={link.icon} /></span>
            <span class="contact-label">{link.label}</span>
            <span class="contact-arrow"><Fragment set:html={arrowIcon} /></span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-description {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    margin-bottom: 40px;
    max-width: 640px;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 16px;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 28px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.2s;
    min-width: 200px;
    flex: 1;
  }

  .contact-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-label {
    font-size: 1rem;
    font-weight: 600;
    flex: 1;
  }

  .contact-arrow {
    color: var(--text-muted);
    transition: transform 0.2s;
    display: flex;
  }

  .contact-arrow svg {
    width: 14px;
    height: 14px;
  }

  .contact-card:hover .contact-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .contact-links {
      flex-direction: column;
    }

    .contact-card {
      min-width: unset;
    }
  }
</style>
