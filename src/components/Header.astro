---
import { useTranslations } from "../i18n/utils";

const { t } = useTranslations(Astro.currentLocale || "es");
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const isEn = Astro.currentLocale === "en";
const otherLocale = isEn ? "es" : "en";
const switchPath = isEn ? base : `${base}en/`;
---

<header class="header">
  <div class="container header-inner">
    <nav class="nav">
      <a href={isEn ? `${base}en/#about` : `${base}#about`} class="nav-link"
        >{t("nav.about")}</a
      >
      <a
        href={isEn ? `${base}en/#projects` : `${base}#projects`}
        class="nav-link">{t("nav.projects")}</a
      >
      <a
        href={isEn ? `${base}en/#experience` : `${base}#experience`}
        class="nav-link">{t("nav.experience")}</a
      >
      <a href={isEn ? `${base}en/#contact` : `${base}#contact`} class="nav-link"
        >{t("nav.contact")}</a
      >
    </nav>
    <a
      href={switchPath}
      class="lang-switch"
      aria-label={t("language.switch_to")}
    >
      {otherLocale === "en" ? "EN" : "ES"}
    </a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(9, 9, 11, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 32px;
  }

  .nav {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: color 0.2s;
    position: relative;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lang-switch:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav {
      gap: 16px;
    }

    .nav-link {
      font-size: 0.75rem;
    }
  }
</style>
