---
import { useTranslations } from "../i18n/utils";

const { t, raw } = useTranslations(Astro.currentLocale || "es");
const projects = raw<
  {
    name: string;
    description: string;
    tech: string[];
    url: string;
    store_url?: string;
    store_label?: string;
  }[]
>("projects.items");
---

<section class="projects" id="projects">
  <div class="container">
    <h2 class="section-title">{t("projects.title")}</h2>
    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <div class="card-header">
              <div class="card-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                </svg>
              </div>
              <h3 class="card-title">{project.name}</h3>
            </div>
            <p class="card-description">{project.description}</p>
            <div class="card-tech">
              {project.tech.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
            <div class="card-links">
              <a
                href={project.url}
                class="card-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {t("projects.view_on_github")}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17l9.2-9.2M17 17V7H7" />
                </svg>
              </a>
              {project.store_url && (
                <a
                  href={project.store_url}
                  class="card-link card-link-store"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.store_label}
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M7 17l9.2-9.2M17 17V7H7" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .project-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .tech-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: var(--bg-tertiary);
    border-radius: 20px;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .card-links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .card-link:hover {
    gap: 10px;
  }

  .card-link-store {
    color: var(--text-secondary);
  }

  .card-link-store:hover {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
